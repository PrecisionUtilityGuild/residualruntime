  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist"
  },
  "include": [
    "src/index.ts",
    "src/mcp/**/*.ts",
    "src/runtime/**/*.ts"
  ],
  "exclude": [
